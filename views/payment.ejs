<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Test Razorpay Payment</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    .container {
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      text-align: center;
    }
    button {
      background: #528FF0;
      color: #fff;
      border: none;
      padding: 12px 20px;
      border-radius: 5px;
      cursor: pointer;
      font-size: 16px;
    }
    button:hover {
      background: #3a6fd8;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>Test Razorpay Payment</h2>
    <button id="payBtn">Pay Now</button>
  </div>

  <!-- Razorpay Checkout Script -->
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    document.getElementById("payBtn").onclick = async function () {
      try {
        // Step 1: Call backend to create Razorpay order
        const response = await fetch("/api/payment/create-order", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ orderId: "69fb73fd9875b0facac8756f" }) // यहाँ existing orderId भेजना है
        });
        const data = await response.json();

        if (!data.razorpayOrderId) {
          alert("Failed to create order: " + data.message);
          return;
        }

        // Step 2: Open Razorpay Checkout
        const options = {
          key: data.key,
          amount: data.amount, // optional
          currency: "INR",
          name: "Test Shop",
          description: "Test Transaction",
          order_id: data.razorpayOrderId,
          handler: async function (response) {
            // Step 3: Send payment details to backend for verification
            const verifyRes = await fetch("/api/payment/verify", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                razorpayOrderId: data.razorpayOrderId,
                razorpayPaymentId: response.razorpay_payment_id,
                razorpaySignature: response.razorpay_signature
              })
            });
            const verifyData = await verifyRes.json();
            alert(JSON.stringify(verifyData));
          },
          theme: { color: "#528FF0" }
        };

        const rzp = new Razorpay(options);
        rzp.open();
      } catch (err) {
        console.error(err);
        alert("Error: " + err.message);
      }
    };
  </script>
</body>
</html>