const jwt = require("jsonwebtoken");

const tokenMiddleware = (req, res, next) => {
  try {
    // Token header से लो
    const token = req.headers.authorization && req.headers.authorization.split(" ")[1];

    if (!token) {
      return res.status(401).json({ message: "No token, access denied" });
    }


    // Token verify करो
    const decoded = jwt.verify(token, process.env.JWT_SECRET); // secretKey वही होना चाहिए जो login में use किया है
    req.user = decoded; // decoded payload को request में attach कर दो

    next(); // आगे controller को call करो
  } catch (error) {
    console.error(error);
    res.status(400).json({ message: "Invalid token" });
  }
};

module.exports = tokenMiddleware;